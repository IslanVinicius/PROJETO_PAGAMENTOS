# ============================================
# CONFIGURAÇÃO FRONTEND - PRODUÇÃO
# ============================================
# Copie este arquivo para .env.production e ajuste conforme necessário

# URL da API Backend
# Opção 1: Caminho relativo (quando servido pelo mesmo servidor Spring Boot)
VITE_API_URL=/api

# Opção 2: URL absoluta (quando frontend e backend estão em servidores diferentes)
# VITE_API_URL=http://SEU_SERVIDOR:8080/api
# Exemplo: VITE_API_URL=https://api.meudominio.com/api
